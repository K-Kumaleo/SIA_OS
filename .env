# Required
ANTHROPIC_API_KEY=

# Optional: ElevenLabs for British "George" voice
# Without this, SIA uses macOS `say` (free, built-in)
ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=hpp4J3VqNfWAUOO0d1Us

# Optional: USRNAME (SIA will address you by name)
# USER_NAME= Kumaleo

# Optional: Specific Apple Calendar accounts (comma-separated emails)
# CALENDAR_ACCOUNTS=you@gmail.com

# Optional: Wake listener
# SIA_WAKE_KEY=SIA
# SIA_WAKE_URL=https://localhost:8340/api/wake
# SIA_CLAP_THRESHOLD=0.30
